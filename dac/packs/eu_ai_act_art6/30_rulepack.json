{
  "id": "eu_ai_act_art6",
  "version": "6.1.0",
  "literals_ref": "20_literals.json",
  "source_ref": "10_source_nodes.json",

  "strict": [
    { "id": "s_sc", "body": [{ "any": ["safety_function", "failure_endangers"] }],
      "head": "safety_component", "ref": "Art 3(14)", "backing": ["src_art3_14"] },
    { "id": "s_pf", "body": ["automated", "personal_data", "evaluate_aspects"],
      "head": "profiling", "ref": "Art 3(52)/GDPR 4(4)", "backing": ["src_art3_52"] }
  ],

  "defeasible": [
    { "id": "sA", "body": ["ai_system", "annexI_regulated", { "any": ["product_itself", "safety_component"] }, "third_party_ca"],
      "head": "high_risk@pathA", "ref": "Art 6(1)", "backing": ["src_art6_1"] },
    { "id": "rB", "body": ["ai_system", "usecase", "permitted_by_law"],
      "head": "high_risk@pathB", "ref": "Art 6(2)", "backing": ["src_art6_2"] },
    { "id": "rFilt", "body": ["usecase", { "any": ["filter_a", "filter_b", "filter_c", "filter_d"] }],
      "head": "not_high_risk", "ref": "Art 6(3)", "backing": ["src_art6_3"] }
  ],

  "undercut": [
    { "id": "eProf",  "body": ["profiling"],        "target": { "ruleId": "rFilt" },
      "ref": "Art 6(3) subpara 3", "backing": ["src_art6_3_sub3"], "note": "プロファイリングはフィルターを無効化" },
    { "id": "eCmplx", "body": ["complex_material"], "target": { "ruleId": "rFilt" },
      "ref": "para 90", "backing": ["src_gl_para90"], "note": "複雑系で決定に実質的影響" },
    { "id": "nFa",    "body": [{ "any": ["ranks_or_scores", "labels_usefulness", "suggests_next"] }], "target": { "ruleId": "rFilt", "via": "filter_a" },
      "ref": "Art 6(3)(a)", "backing": ["src_art6_3_a"], "note": "スコア/ランク付け等は狭い手続的タスクでない" },
    { "id": "nFb",    "body": [{ "any": ["replaces_or_revises", "changes_rights"] }], "target": { "ruleId": "rFilt", "via": "filter_b" },
      "ref": "Art 6(3)(b)", "backing": ["src_art6_3_b"], "note": "結果の置換・権利変更は改善でない" },
    { "id": "nFd",    "body": ["produces_specific_recommendation_or_eval"], "target": { "ruleId": "rFilt", "via": "filter_d" },
      "ref": "Art 6(3)(d)", "backing": ["src_art6_3_d"], "note": "具体的推奨/評価の産出は準備的タスクでない" },
    { "id": "nFc",    "body": ["replaces_or_influences_human_eval"], "target": { "ruleId": "rFilt", "via": "filter_c" },
      "ref": "Art 6(3)(c)", "backing": ["src_art6_3_c"], "note": "人間評価の置換/影響はパターン検知の要件に反する" },
    { "id": "dRev",   "body": ["proper_human_review"], "target": { "ruleId": "nFc" },
      "ref": "Art 6(3)(c)", "backing": ["src_art6_3_c"], "note": "適切な人間レビューが確保されていれば nFc は成立しない" },
    { "id": "dCmplx", "body": ["combined_output_not_decisional"], "target": { "ruleId": "eCmplx" },
      "ref": "para 90", "backing": ["src_gl_para90"], "note": "統合出力が高リスク決定に用いられなければ複雑系オーバーライド不適用" }
  ],

  "conflicts": [["high_risk@pathB", "not_high_risk"]],
  "superiority": [["rFilt", "rB"]],

  "verdict_map": {
    "positive": ["high_risk@pathA", "high_risk@pathB"],
    "negative": ["not_high_risk"],
    "labels": { "positive": "HIGH_RISK", "negative": "NOT_HIGH_RISK", "undetermined": "UNDETERMINED" }
  },
  "policy_beta": "skeptical",

  "obligations": [
    { "id": "obl_art9",  "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "リスク管理システム", "en": "Risk management system" },
      "text": "ライフサイクル全体にわたる継続的なリスク管理システムを確立・実施・文書化・維持する。",
      "ref": "Art 9", "backing": ["src_art9"] },
    { "id": "obl_art10", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "データ・ガバナンス", "en": "Data and data governance" },
      "text": "学習・検証・テストデータの品質基準とデータガバナンス慣行を満たす。",
      "ref": "Art 10", "backing": ["src_art10"] },
    { "id": "obl_art11", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "技術文書", "en": "Technical documentation" },
      "text": "上市前に Annex IV に従った技術文書を作成し最新に保つ。",
      "ref": "Art 11", "backing": ["src_art11"] },
    { "id": "obl_art12", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "ログ記録", "en": "Record-keeping (logging)" },
      "text": "稼働イベントを自動記録（ログ）する機能を備える。",
      "ref": "Art 12", "backing": ["src_art12"] },
    { "id": "obl_art13", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "透明性・使用説明書", "en": "Transparency / instructions for use" },
      "text": "出力を解釈・利用できる透明性を確保し、使用説明書を提供する。",
      "ref": "Art 13", "backing": ["src_art13"] },
    { "id": "obl_art14", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "人間による監督", "en": "Human oversight" },
      "text": "自然人が効果的に監督できるよう設計・開発する。",
      "ref": "Art 14", "backing": ["src_art14"] },
    { "id": "obl_art15", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "正確性・頑健性・サイバーセキュリティ", "en": "Accuracy, robustness, cybersecurity" },
      "text": "適切な正確性・頑健性・サイバーセキュリティを達成する。",
      "ref": "Art 15", "backing": ["src_art15"] },
    { "id": "obl_art17", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "品質管理システム", "en": "Quality management system" },
      "text": "本規則への適合を確保する品質管理システムを整備する。",
      "ref": "Art 17", "backing": ["src_art17"] },
    { "id": "obl_art43", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "適合性評価", "en": "Conformity assessment" },
      "text": "上市・運用開始前に該当する適合性評価手続を完了する。",
      "ref": "Art 43", "backing": ["src_art43"] },
    { "id": "obl_art47", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "EU適合宣言", "en": "EU declaration of conformity" },
      "text": "EU適合宣言書を作成し10年間保持する。",
      "ref": "Art 47", "backing": ["src_art47"] },
    { "id": "obl_art48", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "CEマーキング", "en": "CE marking" },
      "text": "適合性を示すCEマーキングを付す。",
      "ref": "Art 48", "backing": ["src_art48"] },
    { "id": "obl_art49", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "EUデータベース登録", "en": "Registration" },
      "text": "上市・運用開始前にEUデータベースへ登録する。",
      "ref": "Art 49", "backing": ["src_art49"] },
    { "id": "obl_art72", "trigger": "positive", "role": "role_provider", "default_role": true,
      "label": { "ja": "市販後モニタリング", "en": "Post-market monitoring" },
      "text": "市販後モニタリングシステムを確立・文書化する。",
      "ref": "Art 72", "backing": ["src_art72"] },
    { "id": "obl_art26", "trigger": "positive", "role": "role_deployer", "default_role": false,
      "label": { "ja": "デプロイヤ義務", "en": "Deployer obligations" },
      "text": "使用説明書に従った利用、人間監督の割当、入力データの関連性確保、ログ保持、稼働の監視を行う。",
      "ref": "Art 26", "backing": ["src_art26"] }
  ]
}
